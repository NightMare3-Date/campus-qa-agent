# 复制此文件为 .env 并填入实际值
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
SERVER_PORT=8000
# VECTOR_DB_DIR=/path/to/chroma_db  （可选，默认在 ./data/faiss_index  (纯ASCII路径，避免FAISS中文路径问题)）
# KNOWLEDGE_DIR=D:/MySchoolKnowledge  （可选，知识文档路径，默认在项目根 knowledge/）
